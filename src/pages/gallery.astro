---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import '../styles/global.css';
import '../styles/gallery.css';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

export const prerender = true;

const reader = createReader(process.cwd(), keystaticConfig);

const allImages = import.meta.glob('/src/images/**/*.{jpg,jpeg,png,webp,gif,avif}', { eager: true }) as Record<string, { default: ImageMetadata }>;

const homeContent = await reader.singletons.home.read();
const galleries = await reader.singletons.galleries.read();
const images = (galleries?.galleryImages ?? [])
  .filter((item): item is typeof item & { image: string } => !!item.image)
  .map((item, i) => ({
    src: allImages[item.image]?.default,
    alt: item.alt || `CCS Mascots fursuit ${i + 1}`,
  }))
  .filter((item): item is { src: ImageMetadata; alt: string } => !!item.src);
---

<Base
  title="Gallery - CCS Mascots"
  description="Browse our gallery of custom fursuits and mascot costumes handmade in Augusta, Maine."
  author="CCS Mascots"
  twitterSite="@CCSmascots"
  ogImage="/og-image.png"
>

  <Nav />

  <main class="gallery-page">

    <header class="gallery-header">
      <h1 class="gallery-title">Gallery</h1>
      <div class="gallery-header-rule"></div>
    </header>

    <div class="gallery-grid">
      {images.map(({ src, alt }) => (
        <div class="gallery-grid-item is-loading">
          <Image
            src={src}
            alt={alt}
            class="gallery-grid-img is-loading"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>

  </main>

  <script>
  const initGallery = () => {
    const grid = document.querySelector('.gallery-grid') as HTMLElement;
    if (!grid) return;

    const items = Array.from(grid.querySelectorAll('.gallery-grid-item')) as HTMLElement[];

    const lefts = [...new Set(items.map((el) => Math.round(el.getBoundingClientRect().left)))]
      .sort((a, b) => a - b);
    items.forEach((item) => {
      const col = lefts.indexOf(Math.round(item.getBoundingClientRect().left));
      item.style.animationDelay = `${col * 100}ms`;
    });
    items.forEach((item) => item.classList.add('go'));

    const imgs = Array.from(grid.querySelectorAll('.gallery-grid-img')) as HTMLImageElement[];

    const markLoaded = (img: HTMLImageElement) => {
      img.classList.remove('is-loading');
      img.classList.add('is-loaded');
      img.closest('.gallery-grid-item')?.classList.remove('is-loading');
      img.closest('.gallery-grid-item')?.classList.add('has-img');
    };

    imgs.forEach((img) => {
      if (img.complete && img.naturalWidth > 0) {
        markLoaded(img);
      } else {
        img.addEventListener('load', () => markLoaded(img), { once: true });
        img.addEventListener('error', () => markLoaded(img), { once: true }); // don't hang on broken images
      }
    });
  };

  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', initGallery, { once: true });
  } else {
    initGallery();
  }
</script>

  <Footer
  tagline={homeContent?.footer?.footerTagline}
  location={homeContent?.footer?.footerLocation}
  email={homeContent?.footer?.footerEmail}
  facebookUrl={homeContent?.footer?.facebookUrl}
  instagramUrl={homeContent?.footer?.instagramUrl}
  tiktokUrl={homeContent?.footer?.tiktokUrl}
  />

</Base>
