---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import defaultAboutImage from '../images/about/aboutImage.jpg';
import '../styles/about.css';

interface Props {
  title?: string;
  body?: string;
  image?: ImageMetadata;
}
const {
  title = 'About Us',
  body = 'Local to the Maine Furry Community since 2014, we have prided ourselves on providing Quality, Affordable Mascot Style Costumes. We use innovative methods such as 3D modeling and printing, as well as the finest fabrics and materials, to create a comfortable and durable costume that will last for years to come.',
  image = defaultAboutImage,
} = Astro.props as Props;
---

<section class="about" id="about">
  <div class="about-inner">

    <div class="about-text">
      <h2 class="about-heading">{title}</h2>
      <div class="about-rule"></div>
      <p class="about-body">
        {body}
      </p>
    </div>

    <div class="about-img-wrap">
      <Image
        src={image}
        alt="CCS Mascots group photo"
        class="about-img"
      />
    </div>

  </div>
</section>
