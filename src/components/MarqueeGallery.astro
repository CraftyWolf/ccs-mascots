---
interface Props {
  images: string[];
}
const { images } = Astro.props;
---

<div class="hero-right" id="galleryRight"></div>

<script define:vars={{ GALLERY_IMAGES: images }} data-astro-rerun>
(() => {
  // Inject only keyframes + animation assignments globally.
  // All layout/sizing rules already exist in hero.css on the original class names.
  if (!document.getElementById('ccs-marquee-styles')) {
    const s = document.createElement('style');
    s.id = 'ccs-marquee-styles';
    s.textContent = `
      @keyframes ccs-up {
        from { transform: translate3d(0, 0, 0); }
        to   { transform: translate3d(0, var(--ccs-dist), 0); }
      }
      @keyframes ccs-down {
        from { transform: translate3d(0, var(--ccs-dist), 0); }
        to   { transform: translate3d(0, 0, 0); }
      }
      @keyframes ccs-left {
        from { transform: translate3d(0, 0, 0); }
        to   { transform: translate3d(var(--ccs-dist), 0, 0); }
      }
      @keyframes ccs-right {
        from { transform: translate3d(var(--ccs-dist), 0, 0); }
        to   { transform: translate3d(0, 0, 0); }
      }

      .marquee-col.dir-up {
        animation: ccs-up var(--ccs-dur) linear infinite;
      }
      .marquee-col.dir-down {
        animation: ccs-down var(--ccs-dur) linear infinite;
      }
      .row-wrap .marquee-col.dir-up {
        animation: ccs-left var(--ccs-dur) linear infinite;
      }
      .row-wrap .marquee-col.dir-down {
        animation: ccs-right var(--ccs-dur) linear infinite;
      }

      #galleryRight:hover .marquee-col {
        animation-play-state: paused;
      }

      @media (prefers-reduced-motion: reduce) {
        .marquee-col { animation: none !important; }
      }
    `;
    document.head.appendChild(s);
  }

  window.__ccsMarqueeGallery ??= {};
  const state = window.__ccsMarqueeGallery;

  // px/sec — the only value to tune for speed, independent of image count
  const PX_PER_SEC = 80;

  function shuffle(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const IMAGES = shuffle(GALLERY_IMAGES);
  const mobile = () => window.innerWidth <= 768 || window.innerHeight < 830;

  function setNavHeight() {
    const nav = document.querySelector('nav');
    if (nav) document.documentElement.style.setProperty('--nav-h', nav.offsetHeight + 'px');
  }

  function splitImages(n) {
    const buckets = Array.from({ length: n }, () => []);
    IMAGES.forEach((img, i) => buckets[i % n].push(img));
    return buckets;
  }

  function makeItem(src) {
    const d = document.createElement('div');
    if (src) {
      d.className = 'gallery-item is-loading';
      const img = document.createElement('img');
      img.className = 'gallery-item-img is-loading';
      img.src = src;
      img.alt = 'CCS Mascots fursuit';
      img.decoding = 'async';
      img.loading = 'eager';
      img.fetchPriority = 'high';

      const markLoaded = () => {
        d.classList.remove('is-loading');
        d.classList.add('has-img');
        img.classList.remove('is-loading');
        img.classList.add('is-loaded');
      };

      img.addEventListener('load', async () => {
        if (typeof img.decode === 'function') {
          try { await img.decode(); } catch {}
        }
        markLoaded();
      }, { once: true });
      img.addEventListener('error', markLoaded, { once: true });
      if (img.complete && img.naturalWidth > 0) markLoaded();

      d.appendChild(img);
    } else {
      d.className = 'gallery-item';
    }
    return d;
  }

  function makeCol(dir, imgs) {
    const col = document.createElement('div');
    col.className = `marquee-col dir-${dir}`;
    const items = imgs.length > 0 ? imgs : Array(6).fill('');
    [...items, ...items].forEach(src => col.appendChild(makeItem(src)));
    return col;
  }

  // Measures the first half of items to get the true pixel loop distance,
  // then derives duration from PX_PER_SEC so speed never depends on image count.
  function applyAnimation(col, isMob) {
    const items = Array.from(col.children);
    const half = items.length / 2;
    if (half === 0) return;

    // Read the gap from the computed style so we don't hardcode it here
    const gap = parseFloat(getComputedStyle(col).gap) || 0;

    let dist = 0;
    for (let i = 0; i < half; i++) {
      const r = items[i].getBoundingClientRect();
      dist += isMob ? r.width : r.height;
    }
    dist += gap * half; // N items have N gaps after them in the duplicated set

    const durMs = Math.round((dist / PX_PER_SEC) * 1000);
    col.style.setProperty('--ccs-dist', `-${dist}px`);
    col.style.setProperty('--ccs-dur', `${durMs}ms`);
  }

  function measureAll(isMob) {
    const c = document.getElementById('galleryRight');
    if (!c) return;
    c.querySelectorAll('.marquee-col').forEach(col => applyAnimation(col, isMob));
  }

  function buildDesktop(container) {
    container.innerHTML = '';
    const [col1imgs, col2imgs] = IMAGES.length > 0 ? splitImages(2) : [[], []];
    container.appendChild(makeCol('up',   col1imgs));
    container.appendChild(makeCol('down', col2imgs));
  }

  function buildMobile(container) {
    container.innerHTML = '';
    const [row1imgs, row2imgs] = IMAGES.length > 0 ? splitImages(2) : [[], []];
    [['up', row1imgs], ['down', row2imgs]].forEach(([dir, imgs]) => {
      const wrap = document.createElement('div');
      wrap.className = 'row-wrap';
      wrap.appendChild(makeCol(dir, imgs));
      container.appendChild(wrap);
    });
  }

  function build() {
    const c = document.getElementById('galleryRight');
    if (!c) return;
    const isMob = mobile();
    isMob ? buildMobile(c) : buildDesktop(c);
    // Two rAF passes: first lets the browser lay out the new DOM,
    // second ensures getBoundingClientRect returns real painted sizes.
    requestAnimationFrame(() => requestAnimationFrame(() => measureAll(isMob)));
    state.wasMobile = isMob;
  }

  state.build = build;
  state.setNavHeight = setNavHeight;
  state.mobile = mobile;
  state.wasResizeAttached = state.wasResizeAttached ?? false;

  if (!state.wasResizeAttached) {
    state.wasResizeAttached = true;
    window.addEventListener('resize', () => {
      state.setNavHeight?.();
      const now = state.mobile?.() ?? mobile();
      if (now !== state.wasMobile) {
        state.wasMobile = now;
        state.build?.();
      } else {
        requestAnimationFrame(() => requestAnimationFrame(() => measureAll(now)));
      }
    });
  }

  setNavHeight();
  build();
})();
</script>