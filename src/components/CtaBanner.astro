---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import defaultCtaImage from '../images/cta/ctaImage.jpg';
import '../styles/cta.css';

interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  buttonUrl?: string;
  image?: ImageMetadata;
}
const {
  title = 'Ready to Bring Your Character to Life?',
  subtitle = 'Custom fursuits built with love, right here in Maine.',
  buttonText = 'Get a Quote',
  buttonUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSdvfWdapp_bzKXglitzdxh65CiGRf7PifEItHlmHBU5zKwX_Q/viewform',
  image = defaultCtaImage,
} = Astro.props as Props;
---

<section class="cta-banner">
  <Image
    src={image}
    alt=""
    class="cta-bg"
    aria-hidden="true"
  />
  <div class="cta-overlay">
    <h2 class="cta-heading">{title}</h2>
    <p class="cta-sub">{subtitle}</p>
    <a href={buttonUrl} target="_blank" rel="noopener noreferrer" class="btn cta-btn">{buttonText}</a>
  </div>
</section>
